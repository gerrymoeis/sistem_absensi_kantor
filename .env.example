# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_MODE=release  # Use 'debug' for development, 'release' for production
ENVIRONMENT=production  # 'development' or 'production' - affects rate limiting and security features

# Security
JWT_SECRET=change-this-secret-key-in-production  # IMPORTANT: Change this in production!
ALLOWED_IPS=127.0.0.1/32,::1/128,192.168.1.0/24  # Adjust based on your network

# Rate Limiting (automatic based on ENVIRONMENT)
# Development: Login 50/min, API 1000/min (permissive for testing)
# Production: Login 5/min, API 300/min (balanced security)

# Database
DB_DRIVER=sqlite
DB_DSN=./data/absensi.db

# Logging
LOG_LEVEL=info  # Options: debug, info, warn, error
LOG_FILE=./logs/app.log

# Face Recognition
FACE_RECOGNITION_ENABLED=false  # Set to 'true' to enable face recognition
FACE_MODELS_PATH=./models
FACE_MATCH_THRESHOLD=0.6  # Distance threshold for face matching (0.0-1.0)
