# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_MODE=release  # Use 'debug' for development, 'release' for production

# Security
JWT_SECRET=change-this-secret-key-in-production  # IMPORTANT: Change this in production!
ALLOWED_IPS=127.0.0.1/32,::1/128,192.168.1.0/24  # Adjust based on your network

# Database
DB_DRIVER=sqlite
DB_DSN=./data/absensi.db

# Logging
LOG_LEVEL=info  # Options: debug, info, warn, error
LOG_FILE=./logs/app.log
